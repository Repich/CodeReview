# Copy to .env and set actual credentials
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key
# Legacy alias is also supported by code:
OPENAI_APIKEY=your-openai-api-key

# Backend feature flags
CODEREVIEW_MODEL_LAB_ENABLED=false
CODEREVIEW_MODEL_LAB_DEFAULT_SAMPLE_SIZE=10
CODEREVIEW_MODEL_LAB_MAX_SAMPLE_SIZE=20
CODEREVIEW_MODEL_LAB_MAX_MODELS=12
CODEREVIEW_MODEL_LAB_MAX_PAID_TARGET_MODELS=2
CODEREVIEW_MODEL_LAB_MAX_PAID_TARGET_RUNS=40
CODEREVIEW_MODEL_LAB_MAX_EXPERT_MODELS=2
CODEREVIEW_MODEL_LAB_MAX_EXPERT_CALLS=120
